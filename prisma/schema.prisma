generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LoaImport {
  id          String         @id @default(cuid())
  fileName    String
  recordCount Int
  totalValue  Decimal        @db.Decimal(18, 2)
  createdAt   DateTime       @default(now())
  records     BudgetRecord[]
}

model BudgetRecord {
  id                    BigInt    @id @default(autoincrement())
  importId              String
  import                 LoaImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  organ                  String
  budgetUnit             String
  functionName           String
  subfunction            String
  program                String
  action                  String
  expenseNature           String
  subelement              String
  administrativeProcess   String
  value                   Decimal  @db.Decimal(18, 2)
  createdAt               DateTime @default(now())

  @@index([organ])
  @@index([budgetUnit])
  @@index([functionName])
  @@index([subfunction])
  @@index([program])
  @@index([action])
  @@index([expenseNature])
  @@index([subelement])
  @@index([administrativeProcess])
  @@index([value])
  @@index([importId])
}

model BudgetUnit {
  code String @id
  name String
}

model BudgetOrgan {
  code String @id
  name String
}

enum StatusImportacao {
  PROCESSANDO
  CONCLUIDO
  CONCLUIDO_COM_ALERTAS
  ERRO
  CANCELADO
}

model ArquivoImportacao {
  id                  BigInt   @id @default(autoincrement())
  nomeArquivo         String
  tipoArquivo         String?
  tamanhoArquivo      BigInt?
  exercicioReferencia Int?
  quantidadeLinhas    Int      @default(0)
  registrosImportados Int      @default(0)
  registrosIgnorados  Int      @default(0)
  registrosComErro    Int      @default(0)
  status              StatusImportacao @default(PROCESSANDO)
  mensagemErro        String?  @db.Text
  usuarioResponsavel  String?
  iniciadoEm          DateTime @default(now())
  concluidoEm         DateTime?

  receitas ReceitaHistorica[]
}

model ReceitaHistorica {
  id                BigInt    @id @default(autoincrement())
  dataMovimento     DateTime?
  receita           String?
  naturezaReceita   String?
  contabil          String?
  vinculo           String?
  vinculoBanco      String?
  valor             Decimal   @db.Decimal(18, 2)
  descricaoReceita  String?
  descricaoBanco    String?
  prefixoBanco      String?
  numeroBanco       String?
  nomeBanco         String?
  codigo            String?
  unidadeOrcamentaria String?
  exercicio         Int
  unidadeGestora    String?
  idUnidadeGestora  String?
  idSelecionado     String?
  historico         String?   @db.Text
  lote              String?
  sequenciaAvisoCredito String?
  codigoFundo       String?
  descricaoFundo    String?

  arquivoImportacaoId BigInt?
  arquivoImportacao   ArquivoImportacao? @relation(fields: [arquivoImportacaoId], references: [id], onDelete: Cascade)

  hashRegistro       String?  @unique
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  @@index([exercicio])
  @@index([dataMovimento])
  @@index([naturezaReceita])
  @@index([unidadeOrcamentaria])
  @@index([unidadeGestora])
  @@index([vinculo])
  @@index([codigoFundo])
  @@index([receita])
  @@index([arquivoImportacaoId])
}
